<div class="step-panel">
  <div class="panel-header">
    <div class="panel-icon">📍</div>
    <div class="panel-titles">
      <h2 class="panel-title">Résidence administrative</h2>
      <p class="panel-desc">
        Détermine l'indemnité de résidence (BR0) et le supplément familial (CS0).
      </p>
    </div>
    <span class="panel-step-counter">Étape 2 / 6</span>
  </div>

  <div class="panel-body">
    <div class="field-grid field-grid--2">
      <div class="field-group">
        <%= f.label :departement_code, class: "field-label" do %>
          Département de résidence <span class="req">*</span>
        <% end %>
        <%= f.select :departement_code,
            grouped_options_for_select([
              ["Zone 1 — 3%", [["Paris (75)", "75"], ["Hauts-de-Seine (92)", "92"], ["Seine-Saint-Denis (93)", "93"], ["Val-de-Marne (94)", "94"]]],
              ["Zone 2 — 1%", [["Seine-et-Marne (77)", "77"], ["Yvelines (78)", "78"], ["Essonne (91)", "91"], ["Val-d'Oise (95)", "95"]]],
              ["Zone 3 — 0%", [["Autre département", "00"]]]
            ], @simulation.departement_code),
            {}, required: true, data: { action: "change->simulation#updateIr" } %>
      </div>

      <div class="field-group">
        <label class="field-label">Zone IR calculée</label>
        <input type="text" disabled class="field-computed" data-simulation-target="zoneDisplay" value="—"> <%# herb:disable all %>
      </div>

      <div class="field-group">
        <label class="field-label">Indemnité de résidence <span class="badge badge--calc">BR0</span></label>
        <input type="text" disabled class="field-computed" data-simulation-target="irDisplay" value="—"> <%# herb:disable all %>
      </div>

      <div class="field-group">
        <%= f.label :commune, "Commune (optionnel)", class: "field-label" %>
        <%= f.text_field :commune, placeholder: "Ex : Montreuil" %>
      </div>
    </div>

    <div class="section-label" style="margin-top:1.5rem">
      Situation familiale <span class="badge badge--calc">CS0</span>
    </div>

    <div class="field-grid field-grid--3">
      <div class="field-group">
        <%= f.label :nb_enfants_sft, class: "field-label" do %>
          Enfants ouvrant droit SFT <span class="req">*</span>
        <% end %>
        <%= f.select :nb_enfants_sft, (0..6).map { |n| ["#{n} enfant#{n > 1 ? 's' : ''}", n] }, { selected: @simulation.nb_enfants_sft }, required: true, data: { action: "change->simulation#updateSft" } %>
      </div>

      <div class="field-group">
        <label class="field-label">SFT simulé</label>
        <input type="text" disabled class="field-computed" data-simulation-target="sftDisplay" value="0,00 €"> <%# herb:disable all %>
      </div>

      <div class="field-group">
        <%= f.label :garde_alternee, "Garde alternée", class: "field-label" %>
        <%= f.select :garde_alternee, [["Non", false], ["Oui — 50%", true]], { selected: @simulation.garde_alternee }, data: { action: "change->simulation#updateSft" } %>
      </div>
    </div>
  </div>

  <div class="panel-footer">
    <button type="button" class="btn btn--secondary" data-action="click->simulation#prevStep">← Précédent</button>
    <button type="button" class="btn btn--primary" data-action="click->simulation#nextStep">Suivant →</button>
  </div>
</div>
